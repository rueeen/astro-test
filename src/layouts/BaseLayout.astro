---
import "../styles/global.css";
import logoImage from "../assets/logo.png";
import { siteData } from "../data/site";

interface Props {
  title: string;
  description: string;
  keywords?: string[];
}

const { title, description, keywords = [] } = Astro.props;
const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const logoUrl = new URL(logoImage.src, siteUrl).toString();
const ogImage = logoUrl;
const canonicalUrl = Astro.url.href;
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteData.companyName,
  url: siteUrl,
  logo: logoUrl,
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    <meta name="robots" content="index,follow" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <link rel="icon" type="image/png" href={logoImage.src} />
    <link rel="apple-touch-icon" href={logoImage.src} />
    <title>{title}</title>
  </head>
  <body
    class="watermark-bg bg-[#e6f0ff] text-[#003366] antialiased relative min-h-screen"
  >
    <slot />

    <style define:vars={{ logoUrl: `url(${logoImage.src})` }}>
      .watermark-bg::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background-image: var(--logoUrl);
        background-size: 200px;
        background-repeat: repeat;
        background-position: center;
        background-attachment: fixed;
        opacity: 0.5;
        filter: grayscale(80%);
      }
    </style>
  </body>
</html>
