---
import { Image } from "astro:assets";
import aboutImage from "../assets/about.png";

interface Props {
  title: string;
  subtitle: string;
  text: string;
  mission: string;
  vision: string;
}

const { title, subtitle, text, mission, vision } = Astro.props;
---

<section id="nosotros" class="bg-slate-50 py-20">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 lg:grid-cols-2 lg:px-8">
    <div class="space-y-6" data-reveal>
      <p
        class="text-sm font-semibold uppercase tracking-[0.16em] text-amber-600"
      >
        Nosotros
      </p>
      <h2 class="text-3xl font-bold text-[#12264a] md:text-4xl">{title}</h2>
      <p class="text-lg font-medium text-slate-700">{subtitle}</p>
      <p class="text-slate-600">{text}</p>

      <div class="relative w-full rounded-2xl overflow-hidden shadow-lg">
        <Image
          src={aboutImage}
          alt="Operación industrial y energética de EIRP+ con separaciones transparentes"
          class="w-full h-auto object-cover object-center"
          quality="high"
        />
      </div>
    </div>

    <div class="grid gap-6" data-reveal>
      <article class="rounded-2xl bg-white p-7 shadow-sm ring-1 ring-slate-200">
        <h3 class="text-xl font-bold text-[#12264a]">Misión</h3>
        <p class="mt-3 text-slate-600">{mission}</p>
      </article>
      <article class="rounded-2xl bg-[#12264a] p-7 text-slate-100 shadow-sm">
        <h3 class="text-xl font-bold text-amber-300">Visión</h3>
        <p class="mt-3 text-slate-100/95">{vision}</p>
      </article>
    </div>
  </div>
</section>
