---
import { Image } from "astro:assets";
import aboutImage from "../assets/about.png";

interface Props {
  title: string;
  subtitle: string;
  text: string;
  mission: string;
  vision: string;
}

const { title, subtitle, text, mission, vision } = Astro.props;
---

<section id="nosotros" class="relative overflow-hidden bg-[#d9d9d9] py-20">
  <div
    class="relative z-10 mx-auto grid max-w-7xl gap-10 px-5 lg:grid-cols-2 lg:px-8"
  >
    <div class="space-y-6" data-reveal>
      <p
        class="text-sm font-semibold uppercase tracking-[0.16em] text-[#ffaa00]"
      >
        Nosotros
      </p>
      <h2 class="text-3xl font-bold text-[#003366] md:text-4xl">{title}</h2>
      <p class="text-lg font-medium text-[#003366]/85">{subtitle}</p>
      <p class="text-[#003366]/80">{text}</p>

      <div class="relative w-full overflow-hidden rounded-2xl shadow-lg">
        <Image
          src={aboutImage}
          alt="Operación industrial"
          class="h-auto w-full object-cover object-center"
          quality="high"
        />
      </div>
    </div>

    <div class="grid gap-6" data-reveal>
      <article class="rounded-2xl bg-white p-7 shadow-sm ring-1 ring-[#003366]/15">
        <h3 class="text-xl font-bold text-[#003366]">Misión</h3>
        <p class="mt-3 text-[#003366]/80">{mission}</p>
      </article>

      <article
        class="relative overflow-hidden rounded-2xl bg-[#003366] p-7 text-slate-100 shadow-sm"
      >
        <h3 class="relative z-10 text-xl font-bold text-[#ffaa00]">Visión</h3>
        <p class="relative z-10 mt-3 text-slate-100/95">{vision}</p>
      </article>
    </div>
  </div>
</section>
