---
interface Props {
  title: string;
  subtitle?: string;
  light?: boolean;
}

const { title, subtitle, light = false } = Astro.props;
const titleColor = light ? "text-white" : "text-[#003366]";
const subtitleColor = light ? "text-[#ffaa00]" : "text-[#ffaa00]";
const barColor = light ? "bg-[#ffaa00]" : "bg-[#003366]";
---

<div class="flex items-start gap-4" data-reveal>
  <span class:list={["mt-2 h-16 w-2 shrink-0 rounded-full", barColor]}></span>
  <div>
    <h2
      class:list={["text-4xl font-black leading-tight md:text-6xl", titleColor]}
    >
      {title}
    </h2>
    {
      subtitle && (
        <p
          class:list={[
            "mt-2 text-2xl font-semibold md:text-4xl",
            subtitleColor,
          ]}
        >
          {subtitle}
        </p>
      )
    }
  </div>
</div>
