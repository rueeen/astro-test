---
import { Image } from "astro:assets";
import backgroundPic from "../assets/banner1.jpg";

interface Props {
  heading: string;
  subheading: string;
  supportingText: string;
  chips: string[];
  whatsappHref: string;
}

const { heading, subheading, supportingText, chips, whatsappHref } =
  Astro.props;
---

<section
  id="inicio"
  class="relative min-h-screen overflow-hidden bg-slate-950 text-white"
>
  <div class="absolute inset-0">
    <Image
      src={backgroundPic}
      alt="Fondo industrial de EIRP+"
      class="h-full w-full object-cover md:object-contain object-center"
      quality="high"
    />
  </div>

  <div
    class="absolute inset-0 bg-gradient-to-b md:bg-gradient-to-r from-[#0b1831]/90 via-[#12264a]/80 to-[#12264a]/65"
  >
  </div>

  <div
    class="relative mx-auto flex min-h-screen max-w-7xl flex-col justify-center px-5 pb-10 pt-32 lg:px-8"
  >
    <p
      class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-amber-300"
    >
      Operación industrial continua
    </p>
    <h1 class="max-w-3xl text-5xl font-black leading-tight md:text-7xl">
      {heading}
    </h1>
    <h2
      class="mt-3 max-w-3xl text-2xl font-semibold text-slate-100 md:text-4xl"
    >
      {subheading}
    </h2>
    <p class="mt-6 max-w-2xl text-lg text-slate-100/90">{supportingText}</p>

    <div class="mt-8 flex flex-wrap gap-3">
      {
        chips.map((chip) => (
          <span class="rounded-full border border-white/35 bg-white/10 px-4 py-2 text-sm font-medium backdrop-blur-sm">
            {chip}
          </span>
        ))
      }
    </div>

    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href="#contacto"
        class="rounded-full bg-amber-500 px-7 py-3.5 text-base font-semibold text-slate-900 transition hover:bg-amber-400 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-amber-300"
        >Solicitar cotización</a
      >
      <a
        href={whatsappHref}
        target="_blank"
        rel="noreferrer"
        class="rounded-full border border-white/40 px-7 py-3.5 text-base font-semibold text-white transition hover:bg-white/15 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
        >Hablar por WhatsApp</a
      >
    </div>

    <a
      href="#nosotros"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 text-sm text-white/80"
      aria-label="Ir a sección nosotros"
    >
    </a>
  </div>
</section>
