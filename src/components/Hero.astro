---
interface Props {
  heading: string;
  subheading: string;
  supportingText: string;
  chips: string[];
  whatsappHref: string;
}

const { heading, subheading, supportingText, chips, whatsappHref } = Astro.props;
---

<section id="inicio" class="relative min-h-screen overflow-hidden bg-[#0b1831] text-white">
  <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1581092160607-ee22731f9c7c?auto=format&fit=crop&w=2000&q=80')] bg-cover bg-center"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-[#001844]/88 via-[#102a58]/82 to-[#0b1831]/92"></div>

  <div class="relative mx-auto flex min-h-screen max-w-7xl flex-col items-center justify-center px-5 py-24 text-center lg:px-8">
    <div data-reveal class="mx-auto h-28 w-28 rounded-full border-4 border-white/90 bg-white/10 backdrop-blur"></div>
    <h1 data-reveal class="mt-6 text-6xl font-black tracking-wide md:text-7xl">{heading}</h1>
    <p data-reveal class="mt-6 max-w-3xl text-4xl font-black uppercase leading-tight text-amber-400 md:text-6xl">{subheading}</p>
    <p data-reveal class="mt-5 max-w-2xl text-lg text-slate-100/90">{supportingText}</p>

    <div data-reveal class="mt-8 flex flex-wrap justify-center gap-3">
      {chips.map((chip) => (
        <span class="rounded-full border border-white/45 bg-white/10 px-4 py-1.5 text-sm font-semibold uppercase tracking-wide">{chip}</span>
      ))}
    </div>

    <div data-reveal class="mt-10 flex flex-wrap justify-center gap-4">
      <a href="#contacto" class="rounded-full bg-amber-500 px-8 py-3.5 text-base font-bold text-slate-900 transition hover:bg-amber-400">Solicitar cotización</a>
      <a href={whatsappHref} target="_blank" rel="noreferrer" class="rounded-full border border-white/40 px-8 py-3.5 text-base font-semibold hover:bg-white/10">Hablar por WhatsApp</a>
    </div>

    <a href="#nosotros" class="absolute bottom-8 left-1/2 -translate-x-1/2 text-sm font-semibold tracking-wide text-white/90">LIMPIEZA - SEGURIDAD - ENERGÍA</a>
  </div>
</section>
