---
import SectionHeading from './SectionHeading.astro';

interface Reason {
  title: string;
  text: string;
  icon: 'layer' | 'clock' | 'leaf';
}

interface Props {
  reasons: Reason[];
}

const { reasons } = Astro.props;

const iconPathMap: Record<string, string> = {
  layer: 'M4 7l8-4 8 4-8 4-8-4zm0 5l8 4 8-4M4 12v5l8 4 8-4v-5',
  clock: 'M12 8v5l3 3m6-4a9 9 0 11-18 0 9 9 0 0118 0z',
  leaf: 'M5 13c0-6 4-9 9-9 2 0 4 .5 6 1-1 6-5 11-11 11-2 0-3.5-.4-5-1 2-.4 4-1.2 6-2.5'
};
---

<section class="bg-[#eceef1] py-20">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <SectionHeading title="¿Por qué elegir" subtitle="EIRP+?" />

    <div class="mt-12 space-y-6">
      {reasons.map((reason, index) => (
        <article
          data-reveal
          class:list={[
            'grid items-center gap-5 rounded-[2rem] p-7 shadow-sm md:grid-cols-[120px_1fr]',
            index % 2 === 0 ? 'bg-amber-500 text-white' : 'bg-[#1b2d5b] text-white'
          ]}
        >
          <div class="flex h-24 w-24 items-center justify-center rounded-full border-4 border-white/70 bg-white/10">
            <svg class="h-11 w-11" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={iconPathMap[reason.icon]}></path></svg>
          </div>
          <div>
            <h3 class="text-3xl font-black uppercase tracking-wide">{reason.title}</h3>
            <p class="mt-2 text-xl leading-relaxed text-white/95">{reason.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
