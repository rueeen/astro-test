---
// Parte lógica (se ejecuta en tiempo de compilación)
const { titulo, descripcion, icono } = Astro.props;
---
<div class="p-6 bg-white border-l-4 border-blue-900 shadow-md hover:shadow-xl transition-all">
  <span class="text-3xl">{icono}</span>
  <h3 class="text-xl font-bold text-blue-900 mt-4 uppercase">{titulo}</h3>
  <p class="text-gray-600 mt-2">{descripcion}</p>
</div>