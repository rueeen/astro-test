---
import { Image } from "astro:assets";
import logoImage from "../assets/logo.png";

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  links: NavLink[];
  companyName: string;
}

const { links, companyName } = Astro.props;
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-[100] w-full bg-[#003366] py-3 transition-all duration-500 ease-in-out md:py-4"
  data-scrolled="false"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 lg:px-10">
    <a href="#inicio" class="group flex items-center gap-3">
      <Image
        src={logoImage}
        alt={companyName}
        class="h-14 w-auto object-contain transition-all duration-300 group-hover:scale-105 md:h-18"
        data-logo
      />
      <span
        class="hidden text-xl font-black tracking-tighter text-white transition-all duration-300 sm:block md:text-2xl"
        data-brand
      >
        EIRP+
      </span>
    </a>

    <div class="flex items-center gap-6 lg:gap-10">
      <ul class="hidden items-center gap-6 md:flex lg:gap-8">
        {
          links.map((link) => (
            <li>
              <a
                class="text-xs font-bold text-white transition-all hover:text-[#ffaa00] lg:text-sm"
                data-nav-link
                href={link.href}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <a
        href="#contacto"
        class="hidden rounded-full bg-[#ffaa00] px-6 py-2.5 text-xs font-bold text-[#003366] transition-all hover:bg-[#ffd166] md:block lg:px-8 lg:text-sm"
        data-cta
      >
        Solicitar cotización
      </a>

      <button
        id="menu-toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
        class="p-1.5 text-white focus:outline-none md:hidden"
      >
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M4 6h16M4 12h16M4 18h16"
          ></path>
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="mx-4 mt-2 hidden rounded-2xl border border-white/10 bg-[#00264d] p-6 shadow-2xl md:hidden"
  >
    <ul class="flex flex-col gap-4 text-center">
      {
        links.map((link) => (
          <li>
            <a class="block py-1 text-lg font-bold text-white" href={link.href}>
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="border-t border-white/5 pt-3 font-bold">
        <a href="#contacto" class="block rounded-full bg-[#ffaa00] py-3 text-[#003366]">
          Solicitar cotización
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.querySelector("#site-header");
  const toggle = document.querySelector("#menu-toggle");
  const menu = document.querySelector("#mobile-menu");
  const menuLinks = menu?.querySelectorAll("a");

  const updateHeader = () => {
    if (!header) return;

    const isScrolled = window.scrollY > 20;

    if (isScrolled) {
      header.dataset.scrolled = "true";
      header.classList.add("bg-[#00264d]/98", "backdrop-blur-md", "shadow-xl");
      header.classList.remove("bg-[#003366]");
    } else {
      header.dataset.scrolled = "false";
      header.classList.add("bg-[#003366]");
      header.classList.remove("bg-[#00264d]/98", "backdrop-blur-md", "shadow-xl");
    }
  };

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");

    menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
    toggle.setAttribute("aria-label", isOpen ? "Abrir menú" : "Cerrar menú");
  });

  menuLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.setAttribute("aria-label", "Abrir menú");
    });
  });

  window.addEventListener("scroll", updateHeader, { passive: true });
  updateHeader();
</script>