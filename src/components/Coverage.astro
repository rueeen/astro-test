---
import { Image } from "astro:assets";
import mapaCobertura from "../assets/mapa-cobertura-2.png";

interface Props {
  title: string;
  text: string;
  points: string[];
}

const { title, text, points } = Astro.props;

const regionesNorte = [
  { nombre: "Arica", top: "4.5%", left: "52%" },
  { nombre: "Iquique", top: "10%", left: "51%" },
  { nombre: "Antofagasta", top: "18.5%", left: "47%" },
  { nombre: "Calama", top: "16.5%", left: "58%" },
];
---

<section id="cobertura" class="bg-[#0b1831] py-20 text-slate-100">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="mb-16 text-center" data-reveal>
      <h2 class="text-3xl font-bold md:text-4xl">{title}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-slate-300">
        {text}
      </p>
    </div>

    <div class="grid items-center gap-12 lg:grid-cols-2">
      <ul class="space-y-5" data-reveal>
        {
          points.map((point) => (
            <li class="flex items-center gap-4 rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur-md transition-all duration-300 hover:bg-white/10">
              <span class="h-3 w-3 shrink-0 rounded-full bg-amber-400 shadow-[0_0_15px_rgba(251,191,36,0.6)]" />
              <span class="text-lg font-medium text-slate-200">{point}</span>
            </li>
          ))
        }
      </ul>

      <div
        class="relative overflow-hidden rounded-3xl border border-white/10 bg-[#12264a]/40 p-8 shadow-2xl"
        data-reveal
      >
        <p class="absolute left-8 top-8 z-10 text-[10px] font-bold uppercase tracking-[0.3em] text-amber-300/80">
          Cobertura Operativa
        </p>

        <div class="relative mx-auto h-[560px] w-[220px]">
          <Image
            src={mapaCobertura}
            alt="Mapa de cobertura de Chile"
            class="h-full w-full object-contain opacity-90"
          />

          {
            regionesNorte.map((reg) => (
              <div
                class="group absolute cursor-help"
                style={`top: ${reg.top}; left: ${reg.left}; transform: translate(-50%, -50%);`}
              >
                <div class="relative flex items-center justify-center">
                  <div class="absolute h-6 w-6 animate-ping rounded-full bg-amber-400/40" />
                  <div class="relative h-4 w-4 rounded-full border-2 border-[#0b1831] bg-amber-500 shadow-xl transition-transform group-hover:scale-125" />
                </div>

                <div class="pointer-events-none absolute bottom-full left-1/2 mb-4 -translate-x-1/2 whitespace-nowrap rounded-lg bg-white px-4 py-2 text-sm font-bold text-[#0b1831] opacity-0 shadow-[0_10px_20px_rgba(0,0,0,0.3)] transition-all duration-300 group-hover:visible group-hover:-translate-y-2 group-hover:opacity-100">
                  {reg.nombre}
                  <div class="absolute left-1/2 top-full -translate-x-1/2 border-[6px] border-transparent border-t-white" />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>