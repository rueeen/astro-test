---
import { Image } from "astro:assets";
import mapaCobertura from "../assets/mapa-cobertura-2.png";

interface Props {
  title: string;
  text: string;
  points: string[];
}

const { title, text, points } = Astro.props;

const regionesChile = [
  { nombre: "Arica", top: "8.5%", left: "51.5%" },
  { nombre: "Iquique", top: "12.8%", left: "51.5%" },
  { nombre: "Calama", top: "16.2%", left: "55%" },
  { nombre: "Antofagasta", top: "19.5%", left: "52.5%" },
  { nombre: "Santiago", top: "37.5%", left: "49%" },
];
---

<section
  id="cobertura"
  class="relative overflow-hidden bg-[#003366] py-20 text-slate-100"
>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(163,217,165,0.28),_transparent_56%)]"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
    <div
      class="grid items-center gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:gap-16"
    >
      <div
        class="relative overflow-hidden rounded-[32px] bg-[#003366]/60 shadow-[0_30px_60px_rgba(0,0,0,0.35)]"
        data-reveal
      >
        <div class="relative mx-auto h-[860px] w-[320px] py-8">
          <Image
            src={mapaCobertura}
            alt="Mapa de cobertura de Chile"
            class="h-full w-full object-contain opacity-95 saturate-[1.15]"
          />

          {
            regionesChile.map((reg) => (
              <div
                class="group absolute z-10 transition-transform duration-300 hover:scale-110"
                style={`top: ${reg.top}; left: ${reg.left}; transform: translate(-50%, -50%);`}
              >
                <span class="absolute h-6 w-6 -translate-x-1/2 -translate-y-1/2 animate-ping rounded-full bg-[#ffaa00]/30" />

                <span class="relative block h-4 w-4 cursor-pointer rounded-full border-2 border-[#003366] bg-[#ffaa00] shadow-[0_0_15px_rgba(255,170,0,0.9)]" />

                <span
                  class="absolute left-6 top-1/2 -translate-y-1/2 whitespace-nowrap rounded-md bg-[#003366]/95 px-2.5 py-1 text-[11px] font-bold text-white shadow-xl backdrop-blur-sm 
                             pointer-events-none opacity-0 transition-all duration-300 ease-out 
                             group-hover:translate-x-1 group-hover:opacity-100 group-hover:bg-[#ffaa00] group-hover:text-[#003366]"
                >
                  {reg.nombre}
                </span>
              </div>
            ))
          }
        </div>
      </div>

      <div class="space-y-8" data-reveal>
        <div class="text-center lg:text-left">
          <h2 class="text-3xl font-bold leading-tight md:text-5xl">{title}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-300 lg:mx-0">
            {text}
          </p>
        </div>

        <ul class="space-y-4">
          {
            points.map((point) => (
              <li class="flex items-center gap-4 rounded-2xl border border-white/15 bg-white/[0.07] p-5 shadow-[0_10px_35px_rgba(2,6,23,0.4)] backdrop-blur-sm transition-all hover:border-white/30">
                <span class="h-3.5 w-3.5 shrink-0 rounded-full bg-[#ffaa00] shadow-[0_0_16px_rgba(252,211,77,0.95)]" />
                <span class="text-xl font-semibold leading-snug text-slate-200">
                  {point}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
