---
interface Service {
  id: string;
  title: string;
  subtitle?: string;
  intro: string;
  details: string[];
  highlight?: string;
}

interface Props {
  title: string;
  subtitle: string;
  items: Service[];
}

const { title, subtitle, items } = Astro.props;
---

<section id="servicios" class="bg-[#f5f7fa] py-20">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[#ffaa00]">
      Servicios
    </p>
    <h2 class="mt-2 text-3xl font-bold text-[#003366] md:text-4xl">{title}</h2>
    <p class="mt-4 text-lg text-[#003366]/80">{subtitle}</p>

    <div class="mt-10 space-y-4 md:hidden">
      {
        items.map((service, index) => (
          <details
            class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-[#003366]/15"
            data-reveal
          >
            <summary class="cursor-pointer text-lg font-semibold text-[#003366]">
              {index + 1}. {service.title}
            </summary>
            {service.subtitle && (
              <p class="mt-4 font-medium text-[#003366]">{service.subtitle}</p>
            )}
            <p class="mt-3 text-[#003366]/80">{service.intro}</p>
            <ul class="mt-4 list-disc space-y-2 pl-5 text-[#003366]/80">
              {service.details.map((detail) => (
                <li>{detail}</li>
              ))}
            </ul>
            {service.highlight && (
              <p class="mt-4 rounded-xl bg-[#0DFC20]/45 p-3 font-semibold text-[#003366]">
                {service.highlight}
              </p>
            )}
          </details>
        ))
      }
    </div>

    <div class="mt-12 hidden gap-6 md:grid md:grid-cols-3">
      {
        items.map((service) => (
          <article
            data-reveal
            class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-[#003366]/15 transition hover:-translate-y-1 hover:shadow-lg"
          >
            <h3 class="text-2xl font-bold text-[#003366]">{service.title}</h3>
            {service.subtitle && (
              <p class="mt-2 font-semibold text-[#003366]">
                {service.subtitle}
              </p>
            )}
            <p class="mt-3 text-[#003366]/80">{service.intro}</p>
            <ul class="mt-4 space-y-2 text-sm text-[#003366]/80">
              {service.details.map((detail) => (
                <li class="flex gap-2">
                  <span class="mt-1 h-2 w-2 rounded-full bg-[#ffaa00]" />
                  <span>{detail}</span>
                </li>
              ))}
            </ul>
            {service.highlight && (
              <p class="mt-4 rounded-xl bg-[#003366] p-3 font-semibold text-white">
                {service.highlight}
              </p>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
