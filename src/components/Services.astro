---
import SectionHeading from './SectionHeading.astro';

interface Service {
  id: string;
  title: string;
  subtitle?: string;
  intro: string;
  details: string[];
  highlight?: string;
}

interface Props {
  title: string;
  subtitle: string;
  items: Service[];
}

const { title, subtitle, items } = Astro.props;
const images = [
  'https://images.unsplash.com/photo-1621905251918-48416bd8575a?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1509391366360-2e959784a276?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1581092583537-20d51b4b4f1b?auto=format&fit=crop&w=800&q=80'
];
---

<section id="servicios" class="bg-[#eceef1] py-20">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <SectionHeading title={title} subtitle={subtitle.toUpperCase()} />

    <div class="mt-12 space-y-8">
      {items.map((service, index) => (
        <article data-reveal class="rounded-[2.5rem] border-8 border-amber-500 bg-[#1b2d5b] p-6 text-white md:p-8">
          <div class="grid items-center gap-6 md:grid-cols-[180px_1fr]">
            <img src={images[index] || images[0]} alt={`Servicio ${service.title}`} class="h-40 w-40 rounded-full object-cover ring-4 ring-white/70" loading="lazy" />
            <div>
              <h3 class="text-4xl font-black text-white">{service.title}</h3>
              {service.subtitle && <p class="text-2xl font-bold text-amber-300">{service.subtitle}</p>}
              <p class="mt-3 text-lg text-white/95">{service.intro}</p>
              <ul class="mt-4 space-y-2 text-lg">
                {service.details.map((detail) => (
                  <li class="flex gap-2"><span class="mt-2 h-2.5 w-2.5 rounded-full bg-amber-400"></span><span>{detail}</span></li>
                ))}
              </ul>
            </div>
          </div>
          {service.highlight && <p class="mt-6 text-4xl font-black"><span class="text-amber-400">“</span>{service.highlight}<span class="text-amber-400">”</span></p>}
        </article>
      ))}
    </div>
  </div>
</section>
