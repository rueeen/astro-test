---
interface Contact {
  address: string;
  email: string;
  phone: string;
  phoneHref: string;
  whatsappHref: string;
}

interface Props {
  title: string;
  text: string;
  contact: Contact;
}

const { title, text, contact } = Astro.props;
---

<section id="contacto" class="bg-[#eceef1] py-20">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div data-reveal>
        <div class="flex items-center gap-5">
          <div class="h-24 w-24 rounded-full border-4 border-amber-500 bg-white"></div>
          <div>
            <p class="text-6xl font-black text-[#1b2d5b]">EIRP<span class="text-amber-500">+</span></p>
            <p class="text-xl font-bold text-[#1b2d5b]">SOLUCIONES LIMPIAS, OBRAS SEGURAS</p>
          </div>
        </div>

        <ul class="mt-8 space-y-4 text-3xl text-slate-800">
          <li>{contact.address}</li>
          <li><a href={`mailto:${contact.email}`} class="underline decoration-amber-500">{contact.email}</a></li>
          <li><a href={contact.phoneHref} class="underline decoration-amber-500">{contact.phone}</a></li>
        </ul>

        <h3 class="mt-10 text-4xl font-black text-[#1b2d5b]">{title}</h3>
        <p class="mt-3 text-lg text-slate-700">{text}</p>
      </div>

      <form id="formulario-contacto" class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200" novalidate data-reveal>
        <h3 class="text-2xl font-black text-[#1b2d5b]">Solicitar cotización</h3>
        <p class="mt-1 text-sm text-slate-500">Formulario listo para conectar a un endpoint real.</p>

        <div class="mt-5 grid gap-3">
          <label for="nombre" class="font-semibold text-slate-700">Nombre</label>
          <input id="nombre" name="nombre" required class="rounded-xl border border-slate-300 px-4 py-2.5 focus:border-[#1b2d5b] focus:outline-none" />
          <p class="hidden text-sm text-red-600" data-error-for="nombre">Ingresa tu nombre.</p>

          <label for="empresa" class="font-semibold text-slate-700">Empresa</label>
          <input id="empresa" name="empresa" required class="rounded-xl border border-slate-300 px-4 py-2.5 focus:border-[#1b2d5b] focus:outline-none" />
          <p class="hidden text-sm text-red-600" data-error-for="empresa">Ingresa el nombre de tu empresa.</p>

          <label for="telefono" class="font-semibold text-slate-700">Teléfono</label>
          <input id="telefono" name="telefono" required class="rounded-xl border border-slate-300 px-4 py-2.5 focus:border-[#1b2d5b] focus:outline-none" />
          <p class="hidden text-sm text-red-600" data-error-for="telefono">Ingresa un teléfono válido.</p>

          <label for="email" class="font-semibold text-slate-700">Email</label>
          <input id="email" name="email" type="email" required class="rounded-xl border border-slate-300 px-4 py-2.5 focus:border-[#1b2d5b] focus:outline-none" />
          <p class="hidden text-sm text-red-600" data-error-for="email">Ingresa un email válido.</p>

          <label for="mensaje" class="font-semibold text-slate-700">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="4" required class="rounded-xl border border-slate-300 px-4 py-2.5 focus:border-[#1b2d5b] focus:outline-none"></textarea>
          <p class="hidden text-sm text-red-600" data-error-for="mensaje">Describe tu requerimiento.</p>
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          <button type="submit" class="rounded-full bg-amber-500 px-6 py-3 font-bold text-slate-900">Enviar solicitud</button>
          <a href={contact.whatsappHref} target="_blank" rel="noreferrer" class="rounded-full bg-[#1b2d5b] px-6 py-3 font-bold text-white">Escribir por WhatsApp</a>
        </div>
        <p id="form-status" aria-live="polite" class="mt-3 text-sm"></p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector('#formulario-contacto');
  const status = document.querySelector('#form-status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form || !status) return;

    const fields = ['nombre', 'empresa', 'telefono', 'email', 'mensaje'];
    let valid = true;

    fields.forEach((name) => {
      const input = form.elements.namedItem(name);
      const error = form.querySelector(`[data-error-for="${name}"]`);
      if (!(input instanceof HTMLInputElement || input instanceof HTMLTextAreaElement) || !error) return;

      const value = input.value.trim();
      const emailInvalid = name === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
      const phoneInvalid = name === 'telefono' && value.length < 8;
      const invalid = value.length === 0 || emailInvalid || phoneInvalid;

      input.setAttribute('aria-invalid', String(invalid));
      error.classList.toggle('hidden', !invalid);
      if (invalid) valid = false;
    });

    if (!valid) {
      status.textContent = 'Revisa los campos marcados antes de enviar.';
      status.className = 'mt-3 text-sm text-red-600';
      return;
    }

    status.textContent = 'Enviando solicitud...';
    status.className = 'mt-3 text-sm text-slate-600';
    await new Promise((resolve) => setTimeout(resolve, 900));
    status.textContent = 'Solicitud enviada correctamente. Te contactaremos a la brevedad.';
    status.className = 'mt-3 text-sm text-emerald-700';
    form.reset();
  });
</script>
